[Result "*"]
[Annotator "GM Valeriy Aveskulov"]
[SetUp "1"]
[FEN "r1r3k1/2q1bpp1/ppbp1n1p/4p3/P3P3/1BN5/1PPNQPPP/R2R2K1 w - - 0 17"]
